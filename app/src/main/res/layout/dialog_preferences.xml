<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="偏好设置"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="菜系偏好"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_cuisine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:chipSpacing="8dp"
        app:selectionRequired="false"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_cuisine_chinese"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="中餐" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_cuisine_western"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="西餐" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_cuisine_japanese"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="日料" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_cuisine_korean"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="韩餐" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_cuisine_thai"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="泰餐" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_cuisine_italian"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="意餐" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="餐型"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_meal_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:chipSpacing="8dp"
        app:selectionRequired="false"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_meal_breakfast"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="早餐" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_meal_lunch"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="午餐" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_meal_dinner"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="晚餐" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_meal_snack"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="宵夜" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="饮食限制"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_dietary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:chipSpacing="8dp"
        app:selectionRequired="false"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_diet_vegan"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="素食" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_diet_lowcarb"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="低碳水" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_diet_lowfat"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="低脂" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_diet_gluten"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="无麸质" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="过敏原"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_allergies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:chipSpacing="8dp"
        app:selectionRequired="false"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_allergy_nuts"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="坚果" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_allergy_seafood"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="海鲜" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_allergy_lactose"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="乳糖" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_allergy_egg"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="鸡蛋" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_allergy_soy"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="大豆" />
    </com.google.android.material.chip.ChipGroup>

</LinearLayout>
