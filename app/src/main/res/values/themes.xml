<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (default: purple) -->
    <style name="Theme.YesEatWhat" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/theme_pastel_purple</item>
        <item name="colorPrimaryVariant">@color/theme_pastel_purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Pastel Red Theme -->
    <style name="Theme.YesEatWhat.Red">
        <item name="colorPrimary">@color/theme_pastel_red</item>
        <item name="colorPrimaryVariant">@color/theme_pastel_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/theme_pastel_red_dark</item>
    </style>

    <!-- Pastel Blue Theme -->
    <style name="Theme.YesEatWhat.Blue">
        <item name="colorPrimary">@color/theme_pastel_blue</item>
        <item name="colorPrimaryVariant">@color/theme_pastel_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/theme_pastel_blue_dark</item>
    </style>

    <!-- Pastel Yellow Theme -->
    <style name="Theme.YesEatWhat.Yellow">
        <item name="colorPrimary">@color/theme_pastel_yellow</item>
        <item name="colorPrimaryVariant">@color/theme_pastel_yellow_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:statusBarColor">@color/theme_pastel_yellow_dark</item>
    </style>

    <!-- Pastel Green Theme -->
    <style name="Theme.YesEatWhat.Green">
        <item name="colorPrimary">@color/theme_pastel_green</item>
        <item name="colorPrimaryVariant">@color/theme_pastel_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/theme_pastel_green_dark</item>
    </style>

    <!-- Pastel Orange Theme -->
    <style name="Theme.YesEatWhat.Orange">
        <item name="colorPrimary">@color/theme_pastel_orange</item>
        <item name="colorPrimaryVariant">@color/theme_pastel_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/theme_pastel_orange_dark</item>
    </style>

    <!-- Gray (Black/White) Theme -->
    <style name="Theme.YesEatWhat.Gray">
        <item name="colorPrimary">@color/theme_pastel_gray</item>
        <item name="colorPrimaryVariant">@color/theme_pastel_gray_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/theme_pastel_gray_dark</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CircularAvatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>